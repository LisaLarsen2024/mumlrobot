# --- voice-to-claude config ---
# Copy to .env and fill in. .env is gitignored.

# Where this project lives. voice-archive/ and logs/ go inside.
VOICE_BASE_DIR=/Users/yourname/voice-to-claude

# One or more inbox folders to watch, separated by ":" (Unix-style).
# A typical setup: a local inbox + an iCloud Drive folder synced from your phone.
VOICE_INBOXES=/Users/yourname/voice-to-claude/voice-inbox:/Users/yourname/Library/Mobile Documents/com~apple~CloudDocs/voice-inbox

# Telegram bot — create via @BotFather, then send your bot a message
# to get your chat_id from getUpdates.
TELEGRAM_BOT_TOKEN=1234567890:REPLACE_WITH_YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=123456789

# Whisper settings
WHISPER_MODEL=turbo
WHISPER_LANGUAGE=en
WHISPER_INITIAL_PROMPT=

# Filter known Whisper hallucinations (comma-separated, lowercase substring match)
WHISPER_HALLUCINATION_PATTERNS=subtitles by,closed captions,amara.org

# Volume threshold below which we warn about hallucination risk
SILENCE_DB_THRESHOLD=-28

# Claude Code CLI binary — the script calls `claude --print "<prompt>"`.
# Requires a Claude Max subscription so calls do not incur per-message API cost.
CLAUDE_BIN=claude
CLAUDE_TIMEOUT_SECONDS=180
CLAUDE_SYSTEM_PROMPT=You are a personal voice assistant. Reply concisely (max 3 bullet points). Use emoji for visual structure. Confirm what you heard, then act.
